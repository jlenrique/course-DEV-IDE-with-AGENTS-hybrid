# Local secrets — never commit (document keys in docs/admin-guide.md)
.env
.env.*
!.env.example

# Operator local scratch / structure-snapshot drops — not version-controlled
# (Permanent project orientation lives in README.md + docs/dev-guide/langgraph-migration-guide.md)
PROJECT-STRUCTURE-MAP-TEMPORARY.md
PROJECT-STRUCTURE-MAP-*.md

# Cursor / Playwright MCP local logs
.playwright-mcp/

# BMad framework — installed/distributed by bmb; never version-control
_bmad/

# BMad skills distributed to IDE surfaces (installed by bmb setup)
.agents/
.claude/
.cline/
.github/skills/
.cursor/skills/

# Optional local-only drops (large media, exports)
secrets/

# Repo-root storyboard snapshots and zips (generate-storyboard, trial exports)
exports/

# Generated reports (structural walk, prompt harness, etc.)
reports/

# Resources — track structured docs, ignore large binary artifacts
resources/Gamma-visuals/*.png
resources/exemplars/**/reproductions/**/*.png
resources/exemplars/**/reproductions/**/*.pdf
resources/exemplars/**/reproductions/**/*.pptx
resources/exemplars/**/reproductions/**/*.mp3
course-content/**/private/

# Staging workspace — local / mutable; not versioned
course-content/staging/

# Course content — binary media files (stored on Box Drive / local disk, not git)
# Text artifacts (.md, .yaml, .json, .vtt, .csv) remain tracked — they're agent output.
course-content/**/*.pdf
course-content/**/*.pptx
course-content/**/*.docx
course-content/**/*.jpg
course-content/**/*.jpeg
course-content/**/*.png
course-content/**/*.mp3
course-content/**/*.wav
course-content/**/*.zip
course-content/**/*.gif
course-content/**/*.webp

# State runtime (SQLite + backups)
state/runtime/*.db
state/runtime/*.db-journal
state/runtime/backup/*.db
state/runtime/mode_state.json
state/runtime/ad-hoc-observability/
state/runtime/perception-cache/
state/runtime/ad-hoc-runs/
state/runtime/run_baton.*.json

# Generated run context (runtime artifacts; not source-of-truth docs)
state/config/runs/

# Gamma dispatch logs (runtime artifacts from production runs)
gamma-dispatch-*.log

# Live API test harness results (PNGs/JSON from prompt experiments)
tests/prompt-harness-results/

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.ruff_cache/
dist/
build/

# Generated media (large binary assets — keep locally, don't commit)
*.mp4
uv.lock

# Generated quality scan outputs (timestamped run artifacts)
skills/reports/**/quality-scan/**

# OS / editor
.DS_Store
Thumbs.db

# Hybrid-local session guidance (NOT synced with primary — each repo keeps its own)
# See commit message for context; primary repo must mirror this rule + `git rm --cached`
# for the protection to become bidirectional and eliminate delete/modify merge hazards.
next-session-start-here.md
