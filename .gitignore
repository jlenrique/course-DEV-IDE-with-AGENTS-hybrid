# Understand Anything scratch artifacts
.understand-anything/intermediate/
.understand-anything/tmp/
.understand-anything/diff-overlay.json

# Optional: ignore the final generated graph and supporting files until reviewed
# .understand-anything/knowledge-graph.js
# .understand-anything/meta.jsonon
# .understand-anything/fingerprints.json


# Local secrets — never commit (document keys in docs/admin-guide.md)
.env
.env.*
!.env.example

# Operator local scratch / structure-snapshot drops — not version-controlled
# (Permanent project orientation lives in README.md + docs/dev-guide/langgraph-migration-guide.md)
PROJECT-STRUCTURE-MAP-TEMPORARY.md
PROJECT-STRUCTURE-MAP-*.md

# Cursor / Playwright MCP local logs
.playwright-mcp/

# BMad framework — installed/distributed by bmb; never version-control
# EXCEPT `_bmad/memory/` which carries persistent agent sanctum content
# (BMB 6-file pattern: INDEX/PERSONA/CREED/BOND/MEMORY/CAPABILITIES; legacy
# sidecar variants; Class-C+/D2 4-file operational-metadata sidecars). These
# files change with runs / app redevelopment and must be tracked per
# 2026-04-30 operator ratification (retires `bmad-memory-gitignore-force-add-policy`).
# NOTE: glob-direct-children (`_bmad/*`) rather than full-tree (`_bmad/`) so
# the negation `!_bmad/memory/` can re-include the memory subtree (git cannot
# re-include files under a fully-excluded parent dir).
_bmad/*
!_bmad/memory/
# _bmad/custom/ holds installer-never-touched project overrides (config.toml,
# per-skill <skill-name>.toml override files) — hand-authored, so single-disk loss is real; track it.
# Its own .gitignore keeps user-scoped *.user.toml files out. (Party amendment,
# BMAD v6.10.0 upgrade gate 2026-07-11.)
!_bmad/custom/

# BMad skills distributed to IDE surfaces (installed by bmb setup)
# `skills/` itself carries critical agent-definition content (SKILL.md +
# references/ + scripts/) and is tracked. Only IDE-surface mirrors
# (.agents/.claude/.cline/.github/skills/.cursor/skills/.github/agents/)
# are ignored. `.github/agents/` carries BMAD-installer-emitted
# chat-agent persona stubs for GitHub Copilot Chat (5-line redirects
# into the gitignored `.agents/skills/` tree); sibling-but-distinct from
# `.github/instructions/` (file-scoped rules with `applyTo` frontmatter,
# which is tracked). See AGENTS.md for the mechanism distinction.
.agents/
.claude/
.cline/
.github/skills/
.github/agents/
.cursor/skills/

# Optional local-only drops (large media, exports)
secrets/

# Repo-root storyboard snapshots and zips (generate-storyboard, trial exports)
exports/

# Generated reports (structural walk, prompt harness, etc.)
reports/

