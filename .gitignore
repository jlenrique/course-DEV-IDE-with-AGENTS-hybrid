course-content/**/*.pdf
course-content/**/*.pptx
course-content/**/*.docx
course-content/**/*.jpg
course-content/**/*.jpeg
course-content/**/*.png
course-content/**/*.mp3
course-content/**/*.wav
course-content/**/*.zip
course-content/**/*.gif
course-content/**/*.webp

