{
  "$defs": {
    "MotionClipEditPayload": {
      "additionalProperties": false,
      "description": "Field-level edits for the reviewed motion-clip payload.",
      "properties": {
        "edits": {
          "additionalProperties": true,
          "description": "Mapping of motion-clip field names or paths to replacement values.",
          "minProperties": 1,
          "title": "Edits",
          "type": "object"
        }
      },
      "required": [
        "edits"
      ],
      "title": "MotionClipEditPayload",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Tamper-evident verdict emitted by the Section 07F G2F poll surface.",
  "properties": {
    "decision_card_digest": {
      "description": "Lowercase sha256 digest of the reviewed G2C card.",
      "title": "Decision Card Digest",
      "type": "string"
    },
    "edit_payload": {
      "anyOf": [
        {
          "$ref": "#/$defs/MotionClipEditPayload"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Required iff verb is edit."
    },
    "motion_clip_id": {
      "description": "Identifier of the motion clip under review.",
      "minLength": 1,
      "title": "Motion Clip Id",
      "type": "string"
    },
    "operator_id": {
      "description": "Operator identifier.",
      "minLength": 1,
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]+$",
      "title": "Operator Id",
      "type": "string"
    },
    "reject_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Required iff verb is reject.",
      "title": "Reject Reason"
    },
    "run_id": {
      "description": "UUID4 identity for the motion-clip review run.",
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "submitted_at": {
      "description": "Timezone-aware verdict submission time.",
      "format": "date-time",
      "title": "Submitted At",
      "type": "string"
    },
    "surface_id": {
      "const": "section_07f_g2f_motion_gate",
      "default": "section_07f_g2f_motion_gate",
      "description": "Closed Section 07F poll-surface identifier.",
      "title": "Surface Id",
      "type": "string"
    },
    "verb": {
      "description": "Closed verdict verb set: approve | edit | reject.",
      "enum": [
        "approve",
        "edit",
        "reject"
      ],
      "title": "Verb",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "verb",
    "motion_clip_id",
    "operator_id",
    "decision_card_digest"
  ],
  "title": "Section07FOperatorVerdict",
  "type": "object"
}