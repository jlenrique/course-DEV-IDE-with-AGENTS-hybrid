{
  "$defs": {
    "RunConstantsEditPayload": {
      "additionalProperties": false,
      "description": "Field-level run-constants edits keyed by constants path or field name.",
      "properties": {
        "edits": {
          "additionalProperties": true,
          "description": "Mapping of run-constants fields or paths to replacement values.",
          "minProperties": 1,
          "title": "Edits",
          "type": "object"
        }
      },
      "required": [
        "edits"
      ],
      "title": "RunConstantsEditPayload",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Tamper-evident verdict emitted by the Section 04.55 G1.5 surface.",
  "properties": {
    "decision_card_digest": {
      "description": "Lowercase sha256 digest of the reviewed run-constants payload.",
      "title": "Decision Card Digest",
      "type": "string"
    },
    "edit_payload": {
      "anyOf": [
        {
          "$ref": "#/$defs/RunConstantsEditPayload"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Required iff verb is edit."
    },
    "operator_id": {
      "description": "Operator identifier.",
      "minLength": 1,
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]+$",
      "title": "Operator Id",
      "type": "string"
    },
    "reject_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Required iff verb is reject.",
      "title": "Reject Reason"
    },
    "run_constants_id": {
      "description": "Stable identity for the reviewed run-constants payload.",
      "minLength": 1,
      "title": "Run Constants Id",
      "type": "string"
    },
    "run_id": {
      "description": "UUID4 identity for the enclosing run.",
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "submitted_at": {
      "description": "Timezone-aware verdict submission time.",
      "format": "date-time",
      "title": "Submitted At",
      "type": "string"
    },
    "surface_id": {
      "const": "section_04_55_g1_5_run_constants",
      "default": "section_04_55_g1_5_run_constants",
      "description": "Closed Section 04.55 run-constants surface identifier.",
      "title": "Surface Id",
      "type": "string"
    },
    "verb": {
      "description": "lock | edit | reject",
      "enum": [
        "lock",
        "edit",
        "reject"
      ],
      "title": "Verb",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "verb",
    "operator_id",
    "run_constants_id",
    "decision_card_digest"
  ],
  "title": "Section04_55OperatorVerdict",
  "type": "object"
}