{
  "$defs": {
    "PerSlideVariantEditPayload": {
      "additionalProperties": false,
      "description": "Field-level edits keyed by slide id for per-slide variant metadata.",
      "properties": {
        "edits": {
          "additionalProperties": {
            "additionalProperties": true,
            "type": "object"
          },
          "description": "Mapping of slide id to field-level variant updates.",
          "minProperties": 1,
          "title": "Edits",
          "type": "object"
        }
      },
      "required": [
        "edits"
      ],
      "title": "PerSlideVariantEditPayload",
      "type": "object"
    },
    "PerSlideVariantPayload": {
      "additionalProperties": false,
      "description": "Selected A/B variant for one Section 07B slide.",
      "properties": {
        "rationale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional operator rationale for the selected variant.",
          "title": "Rationale"
        },
        "selected_variant": {
          "description": "Selected per-slide variant.",
          "enum": [
            "A",
            "B"
          ],
          "title": "Selected Variant",
          "type": "string"
        }
      },
      "required": [
        "selected_variant"
      ],
      "title": "PerSlideVariantPayload",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Tamper-evident verdict emitted by the Section 07B G2M poll surface.",
  "properties": {
    "decision_card_digest": {
      "description": "Lowercase sha256 digest of the reviewed G2C card.",
      "title": "Decision Card Digest",
      "type": "string"
    },
    "edit_payload": {
      "anyOf": [
        {
          "$ref": "#/$defs/PerSlideVariantEditPayload"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Required iff verb is edit."
    },
    "operator_id": {
      "description": "Operator identifier.",
      "minLength": 1,
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]+$",
      "title": "Operator Id",
      "type": "string"
    },
    "reject_reason": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Required iff verb is reject.",
      "title": "Reject Reason"
    },
    "run_id": {
      "description": "UUID4 identity for the per-slide variant run.",
      "format": "uuid",
      "title": "Run Id",
      "type": "string"
    },
    "select_payload": {
      "anyOf": [
        {
          "$ref": "#/$defs/PerSlideVariantPayload"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Required iff verb is select."
    },
    "slide_id": {
      "description": "Identifier of the slide under A/B variant review.",
      "minLength": 1,
      "title": "Slide Id",
      "type": "string"
    },
    "submitted_at": {
      "description": "Timezone-aware verdict submission time.",
      "format": "date-time",
      "title": "Submitted At",
      "type": "string"
    },
    "surface_id": {
      "const": "section_07b_g2m_per_slide_variant",
      "default": "section_07b_g2m_per_slide_variant",
      "description": "Closed Section 07B per-slide variant surface identifier.",
      "title": "Surface Id",
      "type": "string"
    },
    "verb": {
      "description": "Closed verdict verb set: select | edit | reject.",
      "enum": [
        "select",
        "edit",
        "reject"
      ],
      "title": "Verb",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "verb",
    "slide_id",
    "operator_id",
    "decision_card_digest"
  ],
  "title": "Section07BOperatorVerdict",
  "type": "object"
}