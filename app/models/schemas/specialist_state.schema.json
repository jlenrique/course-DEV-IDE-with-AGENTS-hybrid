{
  "$defs": {
    "ModelResolutionEntry": {
      "additionalProperties": false,
      "description": "One cascade-resolution audit entry (NFR-X4 carrier).",
      "properties": {
        "cache_prefix_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Deterministic SHA-256 hex of the cache-prefix tuple; None for non-final cascade entries that don't carry the cache identity.",
          "title": "Cache Prefix Hash"
        },
        "level": {
          "description": "Closed enum: per_call | per_specialist | registry_default | auto_select_fallback.",
          "enum": [
            "per_call",
            "per_specialist",
            "registry_default",
            "auto_select_fallback"
          ],
          "title": "Level",
          "type": "string"
        },
        "reason": {
          "description": "Free-text explanation of why this level resolved as it did.",
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "requested": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "The model the caller requested at this level (None if no override was provided at this level \u2014 e.g. registry_default level always has requested=None).",
          "title": "Requested"
        },
        "resolved": {
          "description": "The model the cascade resolved to at this level.",
          "minLength": 1,
          "title": "Resolved",
          "type": "string"
        },
        "timestamp": {
          "description": "Timezone-aware resolution timestamp.",
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        }
      },
      "required": [
        "level",
        "resolved",
        "reason",
        "timestamp"
      ],
      "title": "ModelResolutionEntry",
      "type": "object"
    },
    "SpecialistId": {
      "enum": [
        "texas",
        "irene",
        "dan",
        "tracy",
        "gary",
        "kira",
        "wanda",
        "enrique",
        "compositor",
        "quinn_r",
        "vera"
      ],
      "title": "SpecialistId",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Persisted per-specialist state snapshot for adjacent gate pickup.",
  "properties": {
    "artifact_paths": {
      "items": {
        "type": "string"
      },
      "title": "Artifact Paths",
      "type": "array"
    },
    "cache_prefix": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cache Prefix"
    },
    "cache_prefix_hash": {
      "anyOf": [
        {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cache Prefix Hash"
    },
    "gate_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Gate Id"
    },
    "model_resolution_trail": {
      "items": {
        "$ref": "#/$defs/ModelResolutionEntry"
      },
      "title": "Model Resolution Trail",
      "type": "array"
    },
    "schema_version": {
      "const": "specialist-state.v1",
      "default": "specialist-state.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "specialist_id": {
      "$ref": "#/$defs/SpecialistId"
    },
    "status": {
      "default": "pending",
      "enum": [
        "pending",
        "running",
        "completed",
        "deferred",
        "failed"
      ],
      "title": "Status",
      "type": "string"
    },
    "summary_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Summary Path"
    },
    "trial_id": {
      "format": "uuid",
      "title": "Trial Id",
      "type": "string"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "trial_id",
    "specialist_id"
  ],
  "title": "SpecialistState",
  "type": "object"
}
