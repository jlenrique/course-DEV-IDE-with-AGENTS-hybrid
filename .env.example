# =============================================================================
# .env.example — copy to .env + fill with your real credentials
# =============================================================================
#
# Convention per CLAUDE.md sandbox-AC discipline:
# - REQUIRED env vars block trial-run if missing
# - OPTIONAL env vars degrade to pytest.skip OR feature-unavailable warning
# - Live API keys are operator-cost-bearing; skip if not actively running live tests
#
# Validate via:
#   .venv/Scripts/python.exe scripts/utilities/trial_run_preflight.py
#
# =============================================================================
# REQUIRED (preflight FAILS if missing)
# =============================================================================

# OpenAI API access — Slab 1 substrate; Marcus + Cora reasoning loops; specialist LLM tier-cascade
OPENAI_API_KEY=sk-<placeholder>

# =============================================================================
# RECOMMENDED (preflight WARNS if missing; major feature degradation)
# =============================================================================

# LangSmith trace capture — Slab 4 4.3 FR42 evidence; ledger queries; trial-replay regression
LANGSMITH_API_KEY=<placeholder>
LANGSMITH_PROJECT=course-content-production
LANGSMITH_TRACING=true

# Postgres connection (Slab 1 substrate + Slab 4 ledger schema)
# Per CLAUDE.md `project_no_docker` operator preference: Postgres runs natively on host
DATABASE_URL=postgresql://user:pass@localhost:5432/course_dev_ide_migration

# =============================================================================
# OPTIONAL — live third-party APIs (operator-cost-bearing; only set if running live tests)
# =============================================================================

# Wondercraft — podcast production specialist (wanda; per Slab 2c)
# Cost ceiling: $5 for create_scripted_podcast; $1-2 for create_podcast fallback
# Live tests gated by --run-live opt-in (per tests/conftest.py:71)
WONDERCRAFT_API_KEY=<placeholder>

# ElevenLabs — voice synthesis specialist (enrique; per Slab 2b.7)
# Live tests gated by --run-live opt-in
ELEVENLABS_API_KEY=<placeholder>

# Gamma — slide generation specialist (gary; per Slab 2b.1; MCP-routed; key in MCP server config)
# (Configured via .mcp.json gamma server; key sourced from environment by run_mcp_from_env.cjs)
GAMMA_API_KEY=<placeholder>

# Kling — video generation (Slab 2 substrate; per kling_client.py + kling_public_client.py)
KLING_API_KEY=<placeholder>

# scite.ai — citation retrieval provider (texas; per Story 27-2)
# Auth: HTTP Basic
SCITE_USER_NAME=<placeholder>
SCITE_PASSWORD=<placeholder>

# Consensus.app — citation retrieval cross-validation partner (texas; per Story 27-2.5)
# Auth: Bearer token
CONSENSUS_API_KEY=<placeholder>

# Canvas LMS — course content delivery (canvas-lms MCP server; configured via .mcp.json)
CANVAS_API_KEY=<placeholder>
CANVAS_API_DOMAIN=<your-instance>.instructure.com

# Notion — content collaboration (notion MCP server)
NOTION_API_KEY=<placeholder>

# Botpress — conversation orchestration (botpress_client.py; pre-Slab 1 substrate)
BOTPRESS_API_KEY=<placeholder>

# Panopto — video hosting (panopto_client.py)
PANOPTO_CLIENT_ID=<placeholder>
PANOPTO_CLIENT_SECRET=<placeholder>

# Qualtrics — assessment/survey integration (qualtrics_client.py)
QUALTRICS_API_TOKEN=<placeholder>
QUALTRICS_DATA_CENTER=<your-data-center>

# =============================================================================
# OPTIONAL — runtime / orchestration tuning
# =============================================================================

# Override the default Marcus thread namespace prefix (default: run/{trial_id})
# MARCUS_THREAD_NAMESPACE_PREFIX=run

# Override the default Cora dev-graph thread namespace prefix (default: dev/{story_id})
# CORA_THREAD_NAMESPACE_PREFIX=dev

# FastAPI HTTP transport (Slab 3 3.4) — port to bind for gate verdict endpoint
# HTTP_GATE_PORT=8080

# Sanctum-watcher debounce (Slab 4 4.6) — milliseconds to coalesce file events
# SANCTUM_WATCHER_DEBOUNCE_MS=500

# Trial-replay budget override per NFR-X4 (Slab 5a 5a.1; default 900 seconds = 15 min)
# TRIAL_REPLAY_BUDGET_SEC=900

# Optional soft-cap budget for Marcus trial cost reports (Slab 5a 5a.3).
# Unset = no cap; over-budget only warns + emits telemetry, it does not halt mid-trial.
# MARCUS_TRIAL_BUDGET_USD=5.00

# =============================================================================
# OPTIONAL — testing / CI
# =============================================================================

# Pytest opts override (project default lives in pyproject.toml [tool.pytest.ini_options])
# Note: live_api tests are deselected by default; use --run-live to opt in
# PYTEST_ADDOPTS=

# Slab-1 placeholder sentinel — detected by tests/conftest.py for graceful llm_live skip
# (Used internally; do NOT set unless you understand the placeholder discipline)
# OPENAI_API_KEY_PLACEHOLDER_SENTINEL=sk-substrate-no-real-key-do-not-invoke

# =============================================================================
# DEFERRED / PLANNED (referenced in spec headers; NOT yet wired)
# =============================================================================

# Migration-master-status enum value (set at 5a.5 SLAB CLOSING per M5 verdict)
# Values: shipped | iterate-pending | rolled-back
# (Tracked in sprint-status.yaml; this env var is for downstream consumers)
# MIGRATION_MASTER_STATUS=in-flight
