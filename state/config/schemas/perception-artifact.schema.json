          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Producer of the authoritative reading-path tuple.",
      "title": "Reading Path Source"
    },
    "reading_path_degraded": {
      "default": false,
      "description": "True when reading-path classification safe-degraded instead of blocking.",
      "title": "Reading Path Degraded",
      "type": "boolean"
    },
    "reading_path_rationale": {
      "anyOf": [
        {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Short LLM rationale per reading-path tuple axis.",
      "title": "Reading Path Rationale"
    },
    "reading_path_geometry": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Deterministic geometry cross-check telemetry; not authoritative.",
      "title": "Reading Path Geometry"
    },
    "source_png_path": {
      "default": "",
      "title": "Source Png Path",
      "type": "string"
    }
  },
  "required": [
    "confidence",
    "slide_id"
  ],
  "title": "PerceptionArtifact",
  "type": "object"
}
