{
  "additionalProperties": false,
  "description": "Legacy-compatible slide perception summary.\n\nField names intentionally match the pre-existing perception artifact shape\nused by producer scripts; P2-1 only closes the model and adds coverage.\n\nBbox provenance (AC-5, vision-perceiver-real 2026-06-21): each\n``visual_elements[].bbox`` is an APPROXIMATE normalized ``[x1,y1,x2,y2]``\nregion estimate (0..1). These are LLM-estimated and coarse — the\ndeterministic reading-path classifier only buckets element centers into\nthirds, so sub-third bbox precision is neither produced by the live gpt-5.5\nperceiver nor relied upon downstream.",
  "properties": {
    "confidence": {
      "enum": [
        "HIGH",
        "LOW"
      ],
      "title": "Confidence",
      "type": "string"
    },
    "visual_elements": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Visual Elements",
      "type": "array"
    },
    "extracted_text": {
      "default": "",
      "title": "Extracted Text",
      "type": "string"
    },
    "layout_description": {
      "default": "",
      "title": "Layout Description",
      "type": "string"
    },
    "slide_title": {
      "default": "",
      "title": "Slide Title",
      "type": "string"
    },
    "text_blocks": {
      "items": {
        "anyOf": [
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "type": "string"
          }
        ]
      },
      "title": "Text Blocks",
      "type": "array"
    },
    "artifact_path": {
      "default": "",
      "title": "Artifact Path",
      "type": "string"
    },
    "slide_id": {
      "title": "Slide Id",
      "type": "string"
    },
    "card_number": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Card Number"
    },
    "coverage": {
      "default": "perceived",
      "enum": [
        "perceived",
        "low-confidence",
        "not-covered"
      ],
      "title": "Coverage",
      "type": "string"
    },
    "confidence_score": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confidence Score"
    },
    "provider_model_id": {
      "default": "",
      "title": "Provider Model Id",
      "type": "string"
    },
    "reading_path": {
      "anyOf": [
        {
          "enum": [
            "z_pattern",
            "f_pattern",
            "center_out",
            "top_down",
            "multi_column",
            "grid_quadrant",
            "sequence_numbered",
            "split_image_text",
            "two_up_comparison",
            "text_hero_divider",
            "enumerated_process",
            "diagram_driven"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Deterministic reading-path classification derived from perceived geometry.",
      "title": "Reading Path"
    },
    "macro_layout": {
      "anyOf": [
        {
          "enum": [
            "split_image_text",
            "text_hero_divider",
            "multi_column",
            "two_pane",
            "card_grid",
            "center_out",
            "diagram_driven",
            "single_text_block"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Geometry-derived macro-layout axis for the reading-path tuple.",
      "title": "Macro Layout"
    },
    "image_roles": {
      "anyOf": [
        {
          "items": {
            "anyOf": [
              {
                "enum": [
                  "1",
                  "2",
                  "2_5",
                  "3",
                  "4"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Per-element image role tiers emitted or deterministically backfilled in S2.",
      "title": "Image Roles"
    },
    "dominant_image_role": {
      "anyOf": [
        {
          "enum": [
            "1",
            "2",
            "2_5",
            "3",
            "4"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
