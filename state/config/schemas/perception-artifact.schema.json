          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Geometry-derived text-substructure axis for the reading-path tuple.",
      "title": "Text Substructure"
    },
    "narration_cadence": {
      "anyOf": [
        {
          "enum": [
            "sparse_slow",
            "moderate",
            "dense"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Density-derived narration cadence axis for the reading-path tuple.",
      "title": "Narration Cadence"
    },
    "callout_intent": {
      "anyOf": [
        {
          "enum": [
            "invite_response",
            "challenge_quiz",
            "directive_cta"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional callout speech-act axis; S1 leaves this unpopulated for S3.",
      "title": "Callout Intent"
