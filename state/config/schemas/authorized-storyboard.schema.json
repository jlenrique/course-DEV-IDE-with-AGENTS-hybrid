{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://course-dev-ide-with-agents.local/schemas/authorized-storyboard.schema.json",
  "title": "Authorized Storyboard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "slides"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slide_id",
          "title",
          "narration_pointer",
          "motion_pointer",
          "quinn_r_verdict",
          "evidence_block"
        ],
        "properties": {
          "slide_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "narration_pointer": {
            "type": "string",
            "minLength": 1
          },
          "motion_pointer": {
            "type": "string",
            "minLength": 1
          },
          "quinn_r_verdict": {
            "enum": [
              "advisory",
              "blocking",
              "approved"
            ]
          },
          "evidence_block": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
