{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/config/schemas/creative-directive.schema.json",
  "title": "CreativeDirective",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experience_profile",
    "slide_mode_proportions",
    "narration_profile_controls",
    "creative_rationale"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "experience_profile": {
      "type": "string",
      "enum": [
        "visual-led",
        "text-led"
      ]
    },
    "slide_mode_proportions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "literal-text",
        "literal-visual",
        "creative"
      ],
      "properties": {
        "literal-text": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "literal-visual": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "creative": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "narration_profile_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "narrator_source_authority",
        "slide_content_density",
        "elaboration_budget",
        "connective_weight",
        "callback_frequency",
        "visual_narration_coupling",
        "rhetorical_richness",
        "vocabulary_register",
        "arc_awareness",
        "narrative_tension",
        "emotional_coloring"
      ],
      "properties": {
        "narrator_source_authority": {
          "type": "string",
          "enum": [
            "source-grounded",
            "balanced",
            "slide-led"
          ]
        },
        "slide_content_density": {
          "type": "string",
          "enum": [
            "lean",
            "adaptive",
            "dense"
          ]
        },
        "elaboration_budget": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "connective_weight": {
          "type": "string",
          "enum": [
            "light",
            "balanced",
            "heavy"
          ]
        },
        "callback_frequency": {
          "type": "string",
          "enum": [
            "sparse",
            "moderate",
            "frequent"
          ]
        },
        "visual_narration_coupling": {
          "type": "string",
          "enum": [
            "loose",
            "balanced",
            "tight"
          ]
        },
        "rhetorical_richness": {
          "type": "string",
          "enum": [
            "restrained",
            "balanced",
            "expressive"
          ]
        },
        "vocabulary_register": {
          "type": "string",
          "enum": [
            "accessible",
            "professional",
            "specialist"
          ]
        },
        "arc_awareness": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "narrative_tension": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "emotional_coloring": {
          "type": "string",
          "enum": [
            "neutral",
            "warm",
            "vivid"
          ]
        }
      }
    },
    "creative_rationale": {
      "type": "string",
      "minLength": 1
    },
    "gamma_settings": {
      "type": [
        "array",
        "null"
      ],
      "description": "Optional per-variant Gamma settings. Omit for legacy single-dispatch behavior. Known theme/image_style values are documented but intentionally open strings.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "variant_id"
        ],
        "properties": {
          "variant_id": {
            "type": "string",
            "enum": [
              "A",
              "B"
            ]
          },
          "styleguide": {
            "type": "string",
            "description": "Optional name of a CD-owned record in state/config/gamma-style-guides.yaml. When present, its resolved base-layer API keys seed this variant before any explicit per-variant override."
          },
          "theme": {
            "type": "string",
            "description": "Open Gamma theme id/name. Known smoke value: default."
          },
          "template": {
            "type": "string",
            "description": "Open Gamma template id/name. Known smoke value: default."
          },
          "image_style": {
            "type": "string",
            "description": "Open image style. Known smoke values: photographic, diagrammatic, illustrative."
          },
          "amount": {
            "type": "string",
            "enum": [
              "brief",
              "medium",
              "detailed",
              "extensive"
            ]
          },
          "density": {
            "type": "string",
            "enum": [
              "lean",
              "balanced",
              "dense"
            ]
          },
          "tone": {
            "type": "string"
          },
          "audience": {
            "type": "string"
          },
          "language": {
            "type": "string",
            "enum": [
              "en"
            ]
          },
          "text_mode": {
            "type": "string",
            "enum": [
              "generate",
              "condense",
              "preserve"
            ]
          },
          "image_style_preset": {
            "type": "string",
            "enum": [
              "photorealistic",
              "illustration",
              "abstract",
              "3D",
              "lineArt",
              "custom"
            ]
          },
          "image_model": {
            "type": "string",
            "enum": [
              "flux-1-quick",
              "flux-2-klein",
              "flux-kontext-fast",
              "imagen-3-flash",
              "gpt-image-1-mini-low",
              "luma-photon-flash-1",
              "gpt-image-2-mini",
              "flux-1-pro",
              "imagen-3-pro",
              "flux-2-pro",
              "gpt-image-1-mini-medium",
              "ideogram-v3-turbo",
              "luma-photon-1",
              "recraft-v4",
              "leonardo-phoenix",
              "flux-2-flex",
              "flux-2-max",
              "flux-kontext-pro",
              "ideogram-v3",
              "imagen-4-pro",
              "recraft-v3",
              "gemini-2.5-flash-image",
              "gpt-image-1-mini-high",
              "gpt-image-1-medium",
              "gpt-image-2",
              "flux-1-ultra",
              "imagen-4-ultra",
              "dall-e-3",
              "gemini-3.1-flash-image-mini",
              "flux-kontext-max",
              "recraft-v3-svg",
              "recraft-v4-svg",
              "ideogram-v3-quality",
              "gemini-3.1-flash-image",
              "gemini-3-pro-image",
              "gemini-3.1-flash-image-hd",
              "gpt-image-2-hd",
              "gpt-image-1-high",
              "gemini-3-pro-image-hd",
              "recraft-v4-pro"
            ]
          },
          "image_source": {
            "type": "string",
            "enum": [
              "aiGenerated",
              "pexels",
              "webFreeToUse",
              "webFreeToUseCommercially",
              "themeAccent",
              "placeholder",
              "noImages",
              "pictographic",
              "giphy",
              "webAllImages"
            ]
          },
          "dimensions": {
            "type": "string",
            "enum": [
              "fluid",
              "16x9",
              "4x3",
              "pageless",
              "letter",
              "a4",
              "1x1",
              "4x5",
              "9x16"
            ]
          },
          "keywords": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
