{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "state/config/schemas/creative-directive.schema.json",
  "title": "CreativeDirective",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experience_profile",
    "slide_mode_proportions",
    "narration_profile_controls",
    "creative_rationale"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "experience_profile": {
      "type": "string",
      "enum": [
        "visual-led",
        "text-led"
      ]
    },
    "slide_mode_proportions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "literal-text",
        "literal-visual",
        "creative"
      ],
      "properties": {
        "literal-text": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "literal-visual": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "creative": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "narration_profile_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "narrator_source_authority",
        "slide_content_density",
        "elaboration_budget",
        "connective_weight",
        "callback_frequency",
        "visual_narration_coupling",
        "rhetorical_richness",
        "vocabulary_register",
        "arc_awareness",
        "narrative_tension",
        "emotional_coloring"
      ],
      "properties": {
        "narrator_source_authority": {
          "type": "string",
          "enum": [
            "source-grounded",
            "balanced",
            "slide-led"
          ]
        },
        "slide_content_density": {
          "type": "string",
          "enum": [
            "lean",
            "adaptive",
            "dense"
          ]
        },
        "elaboration_budget": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "connective_weight": {
          "type": "string",
          "enum": [
            "light",
            "balanced",
            "heavy"
          ]
        },
        "callback_frequency": {
          "type": "string",
          "enum": [
            "sparse",
            "moderate",
            "frequent"
          ]
        },
        "visual_narration_coupling": {
          "type": "string",
          "enum": [
            "loose",
            "balanced",
            "tight"
          ]
        },
        "rhetorical_richness": {
          "type": "string",
          "enum": [
            "restrained",
            "balanced",
            "expressive"
          ]
        },
        "vocabulary_register": {
          "type": "string",
          "enum": [
            "accessible",
            "professional",
            "specialist"
          ]
        },
        "arc_awareness": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "narrative_tension": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "emotional_coloring": {
          "type": "string",
          "enum": [
            "neutral",
            "warm",
            "vivid"
          ]
        }
      }
    },
    "creative_rationale": {
      "type": "string",
      "minLength": 1
    },
    "gamma_settings": {
      "type": [
        "array",
        "null"
      ],
      "description": "Optional per-variant Gamma settings. Omit for legacy single-dispatch behavior. Known theme/image_style values are documented but intentionally open strings.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "variant_id"
        ],
        "properties": {
          "variant_id": {
            "type": "string",
            "enum": [
              "A",
              "B"
            ]
          },
          "theme": {
            "type": "string",
            "description": "Open Gamma theme id/name. Known smoke value: default."
          },
          "template": {
            "type": "string",
            "description": "Open Gamma template id/name. Known smoke value: default."
          },
          "image_style": {
            "type": "string",
            "description": "Open image style. Known smoke values: photographic, diagrammatic, illustrative."
          },
          "density": {
            "type": "string",
            "enum": [
              "lean",
              "balanced",
              "dense"
            ]
          },
          "tone": {
            "type": "string",
            "enum": [
              "professional",
              "warm",
              "technical"
            ]
          }
        }
      }
    }
  }
}
