# Normalize line endings; Git checks out text as LF on all platforms by default.
* text=auto eol=lf

*.sh text eol=lf
*.{cmd,bat,ps1} text eol=crlf

*.{md,mdc,yml,yaml,json,toml,txt,py,js,mjs,ts,tsx,jsx,css,html,xml} text diff
_bmad/memory/** text=auto eol=lf
tests/fixtures/**/*.mp4 binary

